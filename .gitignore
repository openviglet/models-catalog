# Dependencies (this repo is zero-dependency, but never commit these)
node_modules/

# Generated public artifacts (produced by `npm run emit`; published by CI).
# The browsable public/index.html is committed; only the emitted JSON is ignored.
public/catalog.json
public/catalog-v1.json
public/catalog.schema.json
public/index.json
public/endpoints.json
public/stats.json
public/by-kind/
public/by-vendor/

# Pipeline working dirs are handled by their own .gitignore:
#   pipeline/sources/  (raw per-source snapshot cache)
#   pipeline/out/      (proposed envelope + diff report)

# Python client build/cache artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Java client build output
target/

# Local Claude Code settings (per-machine; not versioned)
.claude/settings.json

# OS / editor noise
.DS_Store
Thumbs.db
