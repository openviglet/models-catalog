# Dependencies (this repo is zero-dependency, but never commit these)
node_modules/

# Generated public artifacts (produced by `npm run emit`; published by CI).
# The browsable public/index.html is committed; only the emitted JSON is ignored.
public/catalog.json
public/catalog-v1.json
public/catalog.schema.json
public/index.json
public/endpoints.json
public/stats.json
public/coverage.json
public/leaderboards.json
public/changes.json
public/feed.xml
public/catalog.csv
public/catalog.ndjson
public/query-manifest.json
public/context.txt
public/qa-eval.jsonl
public/aliases.json
public/badge.json
public/plans.json
public/plans.schema.json
public/providers.json
public/providers.schema.json
public/llms.txt
# Page bundle: TypeScript source lives in src/page/, compiled to public/app/
# by `npm run build:page` (tsc) and in CI before deploy. Emitted → ignored.
# (public/styles.css is hand-authored source and IS committed.)
public/app/
public/by-kind/
public/by-vendor/
public/by-capability/
public/by-modality/
public/models/
public/hubs/
public/sdk/
public/sitemap.xml
public/robots.txt

# Pipeline working dirs are handled by their own .gitignore:
#   pipeline/sources/  (raw per-source snapshot cache)
#   pipeline/out/      (proposed envelope + diff report)

# Python client build/cache artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Java client build output
target/

# Local Claude Code settings (per-machine; not versioned)
.claude/settings.json

# OS / editor noise
.DS_Store
Thumbs.db
